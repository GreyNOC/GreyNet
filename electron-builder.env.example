# =============================================================================
# GreyNet — Windows code-signing environment (TEMPLATE)
#
# Copy this file to `electron-builder.env` (which is git-ignored) and fill in
# the values on the SIGNING machine only. NEVER commit real certificate paths,
# base64 blobs, or passwords. electron-builder reads these variables
# automatically during `npm run build` and signs the .exe artifacts when they
# are present; if they are absent the build still succeeds but is UNSIGNED.
#
# Load it before building, e.g.:
#   PowerShell:  Get-Content electron-builder.env | ForEach-Object {
#                  if ($_ -match '^\s*([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }
#                npm run build
# =============================================================================

# Path to the Authenticode certificate (.pfx/.p12), OR a base64-encoded blob.
# WIN_CSC_LINK is the Windows-specific form; CSC_LINK is the cross-platform one.
WIN_CSC_LINK=
# CSC_LINK=

# Password for the certificate's private key.
WIN_CSC_KEY_PASSWORD=
# CSC_KEY_PASSWORD=

# Optional: RFC-3161 timestamp server (so signatures remain valid after the
# certificate expires). electron-builder defaults to a sane server if unset.
# TIMESTAMP_SERVER=http://timestamp.digicert.com
