{
  "name": "greynet",
  "version": "0.6.1",
  "description": "GreyNet — offline network designer (CAD-style) with City / Planet / Space views.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "security:audit": "npm audit --audit-level=high && node scripts/security-audit.js",
    "check": "node scripts/syntax-check.js",
    "sbom": "npm sbom --sbom-format cyclonedx > sbom.cdx.json",
    "build": "electron-builder --win --x64 --publish=never",
    "build:portable": "electron-builder --win portable --x64 --publish=never",
    "build:installer": "electron-builder --win nsis --x64 --publish=never",
    "dist:checksums": "node scripts/gen-checksums.js",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui"
  },
  "author": "GreyNet",
  "license": "UNLICENSED",
  "dependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.greynet.designer",
    "productName": "GreyNet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "constants.js",
      "state.js",
      "progression.js",
      "validator.js",
      "migrations.js",
      "ui-toast.js",
      "deepspace-mesh.js",
      "orbit-metrics.js",
      "ai-actions.js",
      "app.js",
      "app.css",
      "worldmap.png",
      "package.json",
      "node_modules/leaflet/dist/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "GreyNOC"
    },
    "portable": {
      "artifactName": "GreyNet-${version}-portable.exe"
    },
    "nsis": {
      "artifactName": "GreyNet-${version}-setup.exe",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "GreyNet"
    }
  }
}
