{
  "name": "greynet",
  "version": "1.0.0",
  "description": "GreyNet — offline network designer (CAD-style) with City / Planet / Space views.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "security:audit": "npm audit && node scripts/security-audit.js",
    "build": "electron-builder --win --x64 --publish=never",
    "build:portable": "electron-builder --win portable --x64 --publish=never",
    "build:installer": "electron-builder --win nsis --x64 --publish=never"
  },
  "author": "GreyNet",
  "license": "UNLICENSED",
  "dependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.greynet.designer",
    "productName": "GreyNet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "constants.js",
      "state.js",
      "app.js",
      "app.css",
      "worldmap.png",
      "worldmap.jpg",
      "worldmap.webp",
      "package.json",
      "node_modules/leaflet/dist/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "portable": {
      "artifactName": "GreyNet-${version}-portable.exe"
    },
    "nsis": {
      "artifactName": "GreyNet-${version}-setup.exe",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "GreyNet"
    }
  }
}
