# Normalize line endings to LF in the repository; check out as-is on all platforms.
* text=auto eol=lf

# Explicitly binary — never mangle.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.zip  binary
*.node binary
*.exe  binary
*.dll  binary
